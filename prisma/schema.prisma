// Prisma schema para SQLite.
// SQLite não suporta enums nativos. Campos com valores controlados usam String
// e os valores válidos estão documentados nos comentários.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String   @id @default(cuid())
  name                 String
  email                String   @unique
  password             String
  // role: ALUNO | PROFESSOR | ADMIN
  role                 String   @default("ALUNO")
  // plan: FREE | PRO
  plan                 String   @default("FREE")
  // Perfil pessoal (opcional)
  fotoUrl              String?
  cursoDesejado        String?
  universidadeDesejada String?
  notaDesejada         Int?
  horasPorDia          Int?
  // JSON string: ["seg","ter","qua","qui","sex","sab","dom"]
  diasDisponiveisJson  String   @default("[]")
  // horarioPreferido: MANHA | TARDE | NOITE
  horarioPreferido     String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  aceitouTermosEm      DateTime?

  attempts           Attempt[]
  essays             Essay[]           @relation("AlunoEssays")
  correcoesProfessor Essay[]           @relation("CorretorEssays")
  trackItems         TrackItem[]
  studentProfile     StudentProfile?
  diagnostico        DiagnosticResult?
  simulados          Simulado[]
  revisoes           Revisao[]
  missoes            MissaoDiaria[]
  dailyStats         DailyStats[]
  passwordResetTokens PasswordResetToken[]
  badges             UserBadge[]

  // Stripe billing
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?  @unique
  planUntil            DateTime?

  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Badge {
  id          String  @id @default(cuid())
  slug        String  @unique
  titulo      String
  descricao   String
  icone       String  @default("🏅")
  xpRecompensa Int    @default(50)
  // categoria: QUESTOES | REDACAO | SIMULADO | STREAK | DIAGNOSTICO | ESPECIAL
  categoria   String  @default("ESPECIAL")
  ordem       Int     @default(0)
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  conquistadoEm DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model StudentProfile {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  totalQuestoes            Int       @default(0)
  totalAcertos             Int       @default(0)
  totalErros               Int       @default(0)
  tempoMedioSegundos       Int       @default(0)
  // JSON string: { LINGUAGENS, HUMANAS, NATUREZA, MATEMATICA } 0-100
  areaScoresJson           String    @default("{}")
  // JSON string: { [competencia]: percentual }
  competenciaScoresJson    String    @default("{}")
  // JSON string: { [habilidade]: percentual }
  habilidadeScoresJson     String    @default("{}")
  // JSON string: { [conteudo]: { area, total, acertos, pct } }
  conteudoScoresJson       String    @default("{}")
  // JSON string: array de tags/conteúdos dominados
  dominadosJson            String    @default("[]")
  // JSON string: array de tags/conteúdos fracos
  fracosJson               String    @default("[]")
  // JSON string: array das matérias com dificuldade declarada no diagnóstico
  dificuldadesIniciaisJson String    @default("[]")
  notaInicialAproximada    Int?
  notaEstimadaEnem         Int?
  // Gamificação
  xp                       Int       @default(0)
  // nivel: INICIANTE | APRENDIZ | PERSISTENTE | ESTRATEGISTA | ELITE | ESPECIALISTA | MESTRE | LENDA_ENEM
  nivel                    String    @default("INICIANTE")
  streakDias               Int       @default(0)
  melhorStreak             Int       @default(0)
  ultimoDiaEstudo          DateTime?
  ultimaAtualizacao        DateTime  @default(now())
  // JSON string: array de datas ISO distintas dos últimos 30 dias
  frequenciaDiasJson       String    @default("[]")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DiagnosticResult {
  id             String   @id @default(cuid())
  userId         String   @unique
  // JSON string: { LINGUAGENS, HUMANAS, NATUREZA, MATEMATICA }
  areaScoresJson String
  completedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id                       String   @id @default(cuid())
  year                     Int
  // area: LINGUAGENS | HUMANAS | NATUREZA | MATEMATICA
  area                     String
  disciplina               String
  competencia              String
  habilidade               String
  conteudo                 String
  subconteudo              String?
  enunciado                String
  alternativaA             String
  alternativaB             String
  alternativaC             String
  alternativaD             String
  alternativaE             String
  // correta: A | B | C | D | E
  correta                  String
  comentario               String
  resolucaoPassoPasso      String
  explicacaoSimplificada   String
  explicacaoDetalhada      String
  // JSON string arrays
  conceitosJson            String   @default("[]")
  assuntosRelacionadosJson String   @default("[]")
  dicasJson                String   @default("[]")
  // dificuldade: FACIL | MEDIO | DIFICIL
  dificuldade              String
  tempoMedioSegundos       Int      @default(180)
  geradaPorIA              Boolean  @default(false)
  originalQuestionId       String?
  // JSON string array
  tagsJson                 String   @default("[]")
  vezesUtilizada           Int      @default(0)
  percentualAcertos        Float    @default(0)
  indiceDificuldade        Float    @default(0.5)
  createdAt                DateTime @default(now())

  original  Question?  @relation("Variacoes", fields: [originalQuestionId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  variacoes Question[] @relation("Variacoes")
  attempts  Attempt[]
  revisoes  Revisao[]

  @@index([area])
  @@index([dificuldade])
  @@index([conteudo])
  @@index([originalQuestionId])
}

model Attempt {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  // escolhida: A | B | C | D | E
  escolhida      String
  correta        Boolean
  tempoSegundos  Int
  // tipoErro: CONHECIMENTO|INTERPRETACAO|CALCULO|DISTRACAO|TEMPO|GRAFICO|TABELA|RACIOCINIO|CONCEITUAL|ESTRATEGIA|NENHUM
  tipoErro       String?
  explicacaoErro String?
  createdAt      DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([userId, createdAt])
}

model Essay {
  id                  String    @id @default(cuid())
  userId              String
  tema                String
  texto               String
  // status: ENVIADA | EM_CORRECAO_IA | CORRIGIDA_IA | EM_REVISAO_HUMANA | CORRIGIDA_HUMANA
  status              String    @default("ENVIADA")
  corretorId          String?
  c1                  Int       @default(0)
  c2                  Int       @default(0)
  c3                  Int       @default(0)
  c4                  Int       @default(0)
  c5                  Int       @default(0)
  nota                Int       @default(0)
  comentarioIA        String?
  comentarioProfessor String?
  reescrita           String?
  // JSON string array
  sugestoesJson       String?
  enviadaEm           DateTime  @default(now())
  corrigidaIAem       DateTime?
  corrigidaHumanaEm   DateTime?

  user     User  @relation("AlunoEssays", fields: [userId], references: [id], onDelete: Cascade)
  corretor User? @relation("CorretorEssays", fields: [corretorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model TrackItem {
  id           String    @id @default(cuid())
  userId       String
  ordem        Int
  titulo       String
  descricao    String
  // tipo: QUESTOES | REDACAO | REVISAO | SIMULADO
  tipo         String
  // area: LINGUAGENS | HUMANAS | NATUREZA | MATEMATICA | GERAL
  area         String
  alvoQuestoes Int       @default(5)
  concluido    Boolean   @default(false)
  concluidoEm  DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Simulado {
  id            String    @id @default(cuid())
  userId        String
  titulo        String
  // tipo: TREINO | OFICIAL | PERSONALIZADO | DESAFIO | REVISAO | COMPLETO
  tipo          String
  totalQuestoes Int
  duracaoMin    Int
  iniciadoEm    DateTime  @default(now())
  finalizadoEm  DateTime?
  notaEstimada  Int?
  // JSON string array com IDs de questões em ordem
  questionsJson String
  // JSON string: { [questionId]: { escolhida, tempoSegundos } }
  respostasJson String    @default("{}")
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Revisao {
  id             String   @id @default(cuid())
  userId         String
  questionId     String
  proximaRevisao DateTime
  intervaloDias  Int      @default(1)
  nivelDominio   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@index([proximaRevisao])
}

model MissaoDiaria {
  id                  String    @id @default(cuid())
  userId              String
  data                DateTime
  alvoLinguagens      Int       @default(0)
  alvoHumanas         Int       @default(0)
  alvoNatureza        Int       @default(0)
  alvoMatematica      Int       @default(0)
  alvoRedacao         Int       @default(0)
  alvoRevisoes        Int       @default(0)
  concluidoLinguagens Int       @default(0)
  concluidoHumanas    Int       @default(0)
  concluidoNatureza   Int       @default(0)
  concluidoMatematica Int       @default(0)
  concluidoRedacao    Int       @default(0)
  concluidoRevisoes   Int       @default(0)
  xpBase              Int       @default(50)
  xpGanho             Int?
  concluidaEm         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data])
  @@index([userId])
}

model DailyStats {
  id                 String   @id @default(cuid())
  userId             String
  data               DateTime
  questoesResolvidas Int      @default(0)
  acertos            Int      @default(0)
  tempoSegundos      Int      @default(0)
  redacoes           Int      @default(0)
  revisoes           Int      @default(0)
  xpDia              Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, data])
  @@index([userId, data])
}
